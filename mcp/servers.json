[
  {
    "name": "filesystem",
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
    "env": {}
  },
  {
    "name": "tavily",
    "command": "npx",
    "args": ["-y", "@tavily/mcp"],
    "env": { "TAVILY_API_KEY": "${TAVILY_API_KEY}" }
  },
  {
    "name": "github",
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-github"],
    "env": { "GITHUB_TOKEN": "${GITHUB_TOKEN}" }
  },
  {
    "name": "playwright",
    "command": "npx",
    "args": ["-y", "@playwright/mcp"],
    "env": {}
  }
]
