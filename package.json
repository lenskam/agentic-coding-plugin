{
  "name": "@lens.kamdem/agentic-coding-plugin",
  "version": "1.1.3",
  "description": "Local, autonomous coding assistant framework (inspired from Antigravity) built for OpenCode.",
  "main": "index.js",
  "keywords": [
    "opencode",
    "agentic",
    "autonomous",
    "ai",
    "coding-assistant"
  ],
  "author": "Lenskam",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lenskam/agentic-coding-plugin.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/lenskam/agentic-coding-plugin/issues"
  },
  "homepage": "https://github.com/lenskam/agentic-coding-plugin#readme",
  "bin": {
    "agentic-coding": "src/cli/install.js"
  },
  "files": [
    "dist",
    "python",
    "templates",
    "GEMINI.md",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prebuild": "rimraf dist",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "verify": "node .opencode/tools/verify_setup.js"
  },
  "dependencies": {
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
