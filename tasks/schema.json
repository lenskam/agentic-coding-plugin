{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task Current Tracking",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": { "type": "string" },
      "title": { "type": "string" },
      "description": { "type": "string" },
      "status": {
        "type": "string",
        "enum": ["pending", "in-progress", "done", "failed"]
      },
      "dependencies": {
        "type": "array",
        "items": { "type": "string" }
      },
      "result": { "type": "string" }
    },
    "required": ["id", "title", "status"]
  }
}
