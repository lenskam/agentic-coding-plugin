{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/zen",
  "small_model": "opencode/zen",
  "skills": {
    "paths": [".opencode/skills"]
  },
  "command": {
    "verify": {
      "template": "node .opencode/tools/verify_setup.js"
    },
    "search": {
      "template": "node .opencode/tools/commands/search.js"
    },
    "plan": {
      "template": "node .opencode/tools/commands/plan_task.js"
    },
    "checkRules": {
      "template": "node .opencode/tools/check_rules.js"
    },
    "showChanges": {
      "template": "node .opencode/tools/commands/show_changes.js"
    },
    "undoPreview": {
      "template": "node .opencode/tools/commands/undo_preview.js"
    },
    "undoConfirm": {
      "template": "node .opencode/tools/commands/undo_confirm.js"
    }
  }
}
