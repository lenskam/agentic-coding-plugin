{
  "project": "Agentic Coding Project",
  "llm": {
    "provider": "openrouter",
    "model": "google/gemini-2.0-flash-001",
    "apiKey": "${LLM_API_KEY}"
  },
  "agent": {
    "systemPrompt": ".opencode/prompts/system-prompt.md",
    "autoApprove": false,
    "maxIterations": 10
  },
  "tools": {
    "executionPath": ".opencode/tools",
    "verifySetup": "node .opencode/tools/verify-setup.js"
  },
  "mcp": {
    "servers": ".opencode/mcp-servers.json"
  },
  "rules": {
    "path": ".opencode/rules"
  },
  "workflows": {
    "path": ".opencode/workflows"
  },
  "skills": {
    "path": ".opencode/skills"
  }
}
