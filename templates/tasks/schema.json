{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task List",
  "type": "object",
  "properties": {
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "running", "completed", "failed", "blocked", "retrying"]
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "result": { "type": "string" }
        },
        "required": ["id", "description", "status"]
      }
    }
  }
}
